# GitHub OAuth App 자격증명
# 발급: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   - Homepage URL:               http://localhost:3000
#   - Authorization callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# 요청할 OAuth scope. private 레포에도 커밋하려면 "repo", public만이면 "public_repo"
GITHUB_OAUTH_SCOPE=public_repo

# 배포 시 실제 도메인으로. 로컬 개발은 그대로 둬도 됨.
APP_BASE_URL=http://localhost:3000

# 세션 쿠키 서명용 시크릿 (아무 긴 랜덤 문자열)
#   생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
